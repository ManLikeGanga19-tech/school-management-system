# ═══════════════════════════════════════════════════════════════════════════
# ShuleHQ — PRODUCTION environment (Contabo VPS)
#
# This is the template for the value you paste into the GitHub secret
# PRODUCTION_ENV_FILE (deploy-production.yml composes the live .env from it).
# Fill EVERY change-me. Never commit the filled version. Keep a copy in your
# password manager (it contains the keys that, if lost with the server, lose
# access to integrations).
#
# Cross-reference: docs/ops/SYSTEM_INVENTORY.md §3 (secret inventory).
# ═══════════════════════════════════════════════════════════════════════════

# ── Core ────────────────────────────────────────────────────────────────────
APP_ENV=production
APP_NAME=ShuleHQ
TENANT_MODE=domain
PROD_DOMAIN=shulehq.co.ke

# ── Image pipeline (GHCR) ────────────────────────────────────────────────────
# deploy-production.yml sets these; defaults resolve to :main. Override only to
# pin a specific release tag.
IMAGE_TAG=main

# ── Public host wiring (build/runtime — the class of bug that broke the scanner)
# api.* is a SEPARATE host from the frontend, so the browser base MUST be
# explicit and absolute.
NEXT_PUBLIC_API_BASE_URL=https://api.shulehq.co.ke/api/v1
NEXT_PUBLIC_PUBLIC_HOST=shulehq.co.ke
NEXT_PUBLIC_ADMIN_HOST=admin.shulehq.co.ke
NEXT_PUBLIC_TENANT_BASE_HOST=shulehq.co.ke
# Server-to-server base the frontend uses to reach the API inside the compose
# network (via internal nginx). Not public.
BACKEND_BASE_URL=http://nginx/api/v1

# ── CORS / cookies (HTTPS end-to-end) ────────────────────────────────────────
CORS_ORIGINS=https://shulehq.co.ke,https://www.shulehq.co.ke,https://admin.shulehq.co.ke
CORS_BASE_DOMAIN=shulehq.co.ke
COOKIE_DOMAIN=.shulehq.co.ke
COOKIE_SAMESITE=lax
COOKIE_SECURE=true

# ── Database (Postgres 18 on the VPS) ────────────────────────────────────────
POSTGRES_DB=shulehq
POSTGRES_USER=shulehq
POSTGRES_PASSWORD=change-me-strong-db-password
# Ports stay bound to localhost on the VPS (compose default 127.0.0.1:5432).
# App/migrate containers reach Postgres over the compose network:
DOCKER_DATABASE_URL=postgresql+psycopg://shulehq:change-me-strong-db-password@postgres:5432/shulehq
DATABASE_URL=postgresql+psycopg://shulehq:change-me-strong-db-password@postgres:5432/shulehq
DB_SSL_MODE=disable            # same-host container link; TLS not needed on the private net
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT_SEC=30
DB_POOL_RECYCLE_SEC=1800
DB_POOL_PRE_PING=true

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=change-me-strong-redis-password

# ── Auth / JWT  🔑 (carry JWT_SECRET over VERBATIM at cutover — changing it
#    logs every existing user out) ─────────────────────────────────────────────
JWT_SECRET=change-me-min-32-chars-random
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=30
PUBLIC_OAUTH_SHARED_SECRET=change-me-random

# ── Rate limiting / audit ────────────────────────────────────────────────────
RATE_LIMIT_TENANT_PER_MINUTE=120
AUDIT_LOG_RETENTION_DAYS=365

# ── Gunicorn ─────────────────────────────────────────────────────────────────
GUNICORN_WORKERS=2
GUNICORN_LOG_LEVEL=info

# ── M-Pesa / Daraja  🔑 (re-register the callback URL with Safaricom at cutover)
DARAJA_ENV=production
DARAJA_CONSUMER_KEY=change-me
DARAJA_CONSUMER_SECRET=change-me
DARAJA_PASSKEY=change-me
DARAJA_SHORTCODE=change-me
DARAJA_CALLBACK_BASE_URL=https://api.shulehq.co.ke
DARAJA_CALLBACK_TOKEN=change-me-random
DARAJA_CALLBACK_HMAC_SECRET=change-me-random
DARAJA_DEDUP_WINDOW_SEC=120
DARAJA_TIMEOUT_SEC=30
# BOTH must stay false in production. With the fallback enabled, a failed
# Daraja call writes the payment as status=completed, result_code=0, receipt
# "MOCK..." — a subscription recorded as PAID with no money received (same
# hazard for SMS credit top-ups). A loud failure is always preferable to a
# fabricated payment record. Student fee collection uses a different path.
DARAJA_USE_MOCK=false
DARAJA_SANDBOX_FALLBACK_TO_MOCK=false

# ── SMS / Africa's Talking  🔑 (allowlist the VPS IP with AT if required) ──────
AT_USERNAME=change-me
AT_API_KEY=change-me
AT_SENDER_ID=change-me
AT_SANDBOX=false
AT_USE_MOCK=false
AT_TIMEOUT_SEC=30
AT_UNITS_PER_SEGMENT=1
AT_CHARS_PER_SEGMENT=160

# ── Edge (Caddy) ─────────────────────────────────────────────────────────────
# Email for Let's Encrypt expiry notices.
ACME_EMAIL=ops@shulehq.co.ke
# Cloudflare API token for the WILDCARD TLS DNS-01 challenge (one cert covers
# the apex + api + admin + www + every tenant subdomain). Create it at
# Cloudflare → My Profile → API Tokens → Create Token → "Edit zone DNS"
# template, scoped to Zone → shulehq.co.ke. Permissions: Zone:DNS:Edit +
# Zone:Zone:Read. Paste the token below (never commit it).
CF_API_TOKEN=change-me-cloudflare-scoped-token

# ── Cloudflare Turnstile (login protection) 🔑 ────────────────────────────────
# Guards /api/v1/auth/login. The Cloudflare WAF challenge deliberately EXCLUDES
# /api/* so Safaricom's M-Pesa callbacks are never challenged, which leaves the
# login endpoint — what credential stuffing actually targets — unprotected at
# the edge. Turnstile covers exactly that, without adding friction to page views.
#
# Rollout and rollback are one variable, never a code change:
#   neither set           -> no widget, no verification
#   SITE_KEY only         -> widget renders, token sent, server ignores it
#   SITE_KEY + SECRET_KEY -> enforced
# Blank TURNSTILE_SECRET_KEY to disable instantly with no deploy.
#
# Verification FAILS OPEN if Cloudflare is unreachable: login protection that
# fails closed turns a third-party CAPTCHA outage into an outage for every
# school. Passwords and rate limiting still apply.
#
# Hostname validation is done server-side against CORS_BASE_DOMAIN, not via
# Turnstile's widget hostname list — that list caps at 10 entries and tenants
# are created from the admin dashboard, so per-tenant entries would break on
# the day the 11th school is onboarded.
#
# Cloudflare -> Turnstile -> your widget. Site key is public (it ships in the
# HTML); the secret key is backend-only.
TURNSTILE_SITE_KEY=change-me-public-site-key
TURNSTILE_SECRET_KEY=change-me-secret-key

# ── Dozzle (log viewer, localhost-only) ──────────────────────────────────────
DOZZLE_USERNAME=admin
DOZZLE_PASSWORD=change-me-strong

# ── Backups (Phase 1b automated nightly — optional now) ──────────────────────
# BACKUP_ENCRYPTION_KEY=change-me           # age/gpg recipient for at-rest encryption
# BACKUP_OFFSITE_RCLONE_REMOTE=contabo-obj  # rclone remote for the offsite push
