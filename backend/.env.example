# .env.example

# -----------------------------------------------------------------------------
# Core app settings
# -----------------------------------------------------------------------------
APP_ENV=dev
APP_NAME=School Management System API
TENANT_MODE=domain

# -----------------------------------------------------------------------------
# Compose exposed ports
# -----------------------------------------------------------------------------
NGINX_HTTP_PORT=8080
FRONTEND_PORT=3000
BACKEND_PORT=8000
POSTGRES_PORT=5432
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Database (local Compose defaults)
# -----------------------------------------------------------------------------
POSTGRES_DB=school_management
POSTGRES_USER=sms_user
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+psycopg://sms_user:change-me@postgres:5432/school_management

# -----------------------------------------------------------------------------
# Auth / security
# -----------------------------------------------------------------------------
JWT_SECRET=change-me-super-secret-min-32-chars
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=30

# -----------------------------------------------------------------------------
# SQLAlchemy pool tuning
# -----------------------------------------------------------------------------
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT_SEC=30
DB_POOL_RECYCLE_SEC=1800
DB_POOL_PRE_PING=true

# -----------------------------------------------------------------------------
# Audit middleware tuning
# -----------------------------------------------------------------------------
AUDIT_QUEUE_MAXSIZE=2000
AUDIT_WORKERS=1
AUDIT_POOL_RESERVE=4

# -----------------------------------------------------------------------------
# Frontend runtime env
# -----------------------------------------------------------------------------
# Cookie security for Next auth cookies.
# Set false on plain HTTP staging/local; set true behind HTTPS.
COOKIE_SECURE=false
# Browser-side API base (through Nginx in dev/prod).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1
# Server-side API base for Next API routes (inside Compose network).
BACKEND_BASE_URL=http://nginx/api/v1
BACKEND_FETCH_TIMEOUT_MS=20000
AUTH_LOGIN_TIMEOUT_MS=60000

# -----------------------------------------------------------------------------
# Daraja STK (set real values before payment testing)
# -----------------------------------------------------------------------------
DARAJA_ENV=sandbox
DARAJA_CONSUMER_KEY=
DARAJA_CONSUMER_SECRET=
DARAJA_SHORTCODE=
DARAJA_PASSKEY=
DARAJA_CALLBACK_BASE_URL=
DARAJA_CALLBACK_TOKEN=
DARAJA_TIMEOUT_SEC=30
DARAJA_USE_MOCK=false
DARAJA_SANDBOX_FALLBACK_TO_MOCK=false

# -----------------------------------------------------------------------------
# Production image tags (docker-compose.prod.yml)
# -----------------------------------------------------------------------------
IMAGE_TAG=main
BACKEND_IMAGE=ghcr.io/manlikeganga19-tech/school-management-system-backend:main
FRONTEND_IMAGE=ghcr.io/manlikeganga19-tech/school-management-system-frontend:main
NGINX_IMAGE=ghcr.io/manlikeganga19-tech/school-management-system-nginx:main

# -----------------------------------------------------------------------------
# Deployment metadata (planning / docs)
# -----------------------------------------------------------------------------
STAGING_DOMAIN=staging.shulehq.co.ke
PROD_DOMAIN=shulehq.co.ke
DO_REGION=fra1
GHCR_OWNER=manlikeganga19-tech
