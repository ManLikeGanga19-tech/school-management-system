# infra/deploy/production.env.example

APP_NAME=School Management System API
TENANT_MODE=domain
NODE_ENV=production
COOKIE_SECURE=true

# Network / public endpoints
NEXT_PUBLIC_API_BASE_URL=/api/v1
BACKEND_BASE_URL=http://nginx/api/v1
NEXT_STATIC_CACHE_CONTROL=public,max-age=31536000,immutable
POSTGRES_PORT=127.0.0.1:5432
REDIS_PORT=127.0.0.1:6379
BACKEND_PORT=127.0.0.1:8000
FRONTEND_PORT=127.0.0.1:3000
NGINX_HTTP_PORT=80

# Database / cache
POSTGRES_DB=school_manager_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-password
DATABASE_URL=postgresql+psycopg://postgres:replace-with-strong-password@postgres:5432/school_manager_db
REDIS_URL=redis://redis:6379/0

# Auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=30

# API timeouts
BACKEND_FETCH_TIMEOUT_MS=20000
AUTH_LOGIN_TIMEOUT_MS=60000

# Pool tuning
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT_SEC=30
DB_POOL_RECYCLE_SEC=1800
DB_POOL_PRE_PING=true

# Audit tuning
AUDIT_QUEUE_MAXSIZE=2000
AUDIT_WORKERS=1
AUDIT_POOL_RESERVE=4

# Daraja (production)
DARAJA_ENV=production
DARAJA_CONSUMER_KEY=
DARAJA_CONSUMER_SECRET=
DARAJA_SHORTCODE=
DARAJA_PASSKEY=
DARAJA_CALLBACK_BASE_URL=
DARAJA_CALLBACK_TOKEN=
DARAJA_TIMEOUT_SEC=30
DARAJA_USE_MOCK=false
DARAJA_SANDBOX_FALLBACK_TO_MOCK=false
