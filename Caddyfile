# ═══════════════════════════════════════════════════════════════════════════
# ShuleHQ — Caddy edge (Phase 2). The only internet-facing service.
#
# Terminates TLS for every hostname and reverse-proxies to the internal nginx
# (which routes by path: /api/v1 → backend, else → frontend). The Host header
# is preserved so the frontend resolves tenant / admin / public context.
#
# TLS: a single WILDCARD certificate for shulehq.co.ke + *.shulehq.co.ke,
# issued via the ACME DNS-01 challenge using the Cloudflare plugin. One cert
# covers the apex, api, admin, www, AND every tenant subdomain — so onboarding
# unlimited schools from the admin dashboard never touches Let's Encrypt's
# 50-certs/week/domain limit. Requires the custom Caddy image
# (deploy/caddy/Dockerfile) + a Cloudflare API token (CF_API_TOKEN) scoped to
# Zone:DNS:Edit for shulehq.co.ke.
#
# Marketing sites live on separate registered domains → ordinary HTTP-01.
# ═══════════════════════════════════════════════════════════════════════════

{
	email {$ACME_EMAIL}
}

# Shared proxy behaviour → internal nginx (path-based routing lives there).
(to_app) {
	encode zstd gzip
	reverse_proxy nginx:80 {
		header_up Host {host}
		header_up X-Forwarded-Proto {scheme}
		# X-Forwarded-For is deliberately NOT set to {remote_host}: that
		# REPLACES the incoming chain, so once Cloudflare fronts the origin
		# every request arrived downstream looking like it came from a
		# Cloudflare edge address. The real client was unrecoverable, which
		# silently collapsed all unauthenticated rate limiting into a single
		# shared bucket. Caddy appends the peer to the existing chain by
		# default, which preserves the original client as the left-most entry.
		#
		# CF-Connecting-IP passes through untouched (Caddy forwards unknown
		# headers), and the application prefers it. X-Real-IP stays the direct
		# peer for nginx's own logging.
		header_up X-Real-IP {remote_host}
	}
	# Baseline security headers (HSTS: 1 year, preload-eligible).
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
}

# ── Apex + every subdomain (api, admin, www, and all tenants) ────────────────
# One wildcard cert via Cloudflare DNS-01. The apex must be listed explicitly
# because a wildcard (*.shulehq.co.ke) does not itself match the bare apex.
shulehq.co.ke, *.shulehq.co.ke {
	tls {
		dns cloudflare {env.CF_API_TOKEN}
		resolvers 1.1.1.1 8.8.8.8
	}
	import to_app
}

# ── Marketing sites (separate registered domains) — automatic HTTP-01 ────────
# Add each marketing domain here, comma-separated, when they move to the VPS:
# example-marketing-1.com, www.example-marketing-1.com {
#     root * /srv/marketing/site1
#     file_server
# }
